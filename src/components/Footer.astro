<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__col">
      <h3 class="footer__logo">Carmella</h3>
      <p class="footer__desc">Gelatos de raízes italianas feitos artesanalmente e com ingredientes de altíssima qualidade.</p>
      <div class="footer__socials">
        <!-- Substituir por ícones SVG reais posteriormente -->
        <a href="#" aria-label="Instagram">IG</a>
        <a href="#" aria-label="Facebook">FB</a>
        <a href="#" aria-label="WhatsApp">WA</a>
      </div>
    </div>

    <div class="footer__col">
      <h4>Links Rápidos</h4>
      <ul>
        <li><a href="#sobre">Sobre Nós</a></li>
        <li><a href="#sabores">Menu de Sabores</a></li>
        <li><a href="#lojas">Onde Encontrar</a></li>
        <li><a href="#eventos">Eventos e Encomendas</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Contato</h4>
      <ul>
        <li>Rua dos Gelatos, 123 - Centro, Curitiba/PR</li>
        <li>(41) 3000-0000</li>
        <li>contato@carmellagelateria.com.br</li>
      </ul>
    </div>
  </div>
  
  <div class="footer__bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Carmella Gelateria. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use "../styles/global/variables" as *;

  .footer {
    background-color: $black;
    color: $white;
    padding-top: 8rem;

    &__inner {
      display: grid;
      grid-template-columns: 2fr 1fr 1.5fr;
      gap: 4rem;
      margin-bottom: 6rem;
    }

    &__logo {
      font-family: 'Montserrat', sans-serif;
      font-size: 2.8rem;
      font-weight: 700;
      color: $mainColor;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 2rem;
    }

    &__desc {
      color: #999;
      font-size: 1.5rem;
      line-height: 1.6;
      margin-bottom: 3rem;
      max-width: 350px;
    }

    &__socials {
      display: flex;
      gap: 1.5rem;
      
      a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background-color: #333;
        color: $white;
        border-radius: 50%;
        text-decoration: none;
        font-size: 1.2rem;
        font-weight: 700;
        transition: background 0.3s ease;
        
        &:hover {
          background-color: $mainColor;
        }
      }
    }

    &__col {
      h4 {
        font-size: 1.8rem;
        color: $white;
        margin-bottom: 2.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        
        li {
          margin-bottom: 1.5rem;
          color: #999;
          font-size: 1.5rem;
          line-height: 1.5;

          a {
            color: #999;
            text-decoration: none;
            transition: color 0.3s;

            &:hover {
              color: $mainColor;
            }
          }
        }
      }
    }

    &__bottom {
      border-top: 1px solid #333;
      padding: 2.5rem 0;
      text-align: center;
      
      p {
        color: #777;
        font-size: 1.4rem;
        margin: 0;
      }
    }

    @media (max-width: 768px) {
      &__inner {
        grid-template-columns: 1fr;
        gap: 5rem;
      }
    }
  }
</style>