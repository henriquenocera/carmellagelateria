---
import BaseHead from '../layout/BaseHead.astro'
import BaseBody from '../layout/BaseBody.astro'

import '../styles/pages/index.scss' // Page Style



const title = "Carmella Gelateria Artigianale"
const description = `O melhor Gelato da cidade !`
const url = "https://www.carmellagelateria.com.br/"
---


<html lang="pt-BR">
<BaseHead title={title} description={description} url={url} />
<BaseBody>

  <section class="mapa-lojas">
    <h2 style="text-align:center; color:#b48a78; margin-bottom:1rem;">Veja nossas lojas no mapa</h2>
    <div class="mapa-container">
      <iframe src="https://www.google.com/maps/d/u/0/embed?mid=1W403tPeepOKoGsfBx6-EBmAEP_RITjo&ehbc=2E312F&noprof=1"
        width="100%" height="480" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        title="Mapa das Lojas Carmella"></iframe>

    </div>
  </section>

  <section class="hero">

    <div class="lojas-lista">
      <div class="loja clean">
        <h2>Loja Ahu</h2>
        <p>Rua Colombo, 183</p>
        <a href="https://maps.app.goo.gl/sQGPvPWkoKmyyEnJ7" target="_blank">Ver no Google Maps</a>
      </div>
      <div class="loja clean">
        <h2>Loja Alto da XV</h2>
        <p>Rua Sete de Abril, 934</p>
        <a href="https://maps.app.goo.gl/MyqbkkQwz1wZDCRT8" target="_blank">Ver no Google Maps</a>
      </div>
      <div class="loja clean">
        <h2>Loja Batel</h2>
        <p>Rua Sete de Setembro, 4837</p>
        <a href="https://maps.app.goo.gl/uKX1UMHVECMj5p2F8" target="_blank">Ver no Google Maps</a>
      </div>
    </div>
  </section>

  <style>
    .mapa-container {
      width: 90%%;
      max-width: 900px;
      margin: 0 auto 2.5rem auto;
      box-shadow: 0 4px 24px rgba(180, 138, 120, 0.10);
      border-radius: 16px;
      overflow: hidden;
    }

    .lojas-lista {
      margin-bottom: 80px;
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
      margin-top: 2rem;
    }

    .loja.clean {
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 2px 8px rgba(180, 138, 120, 0.07);
      padding: 2rem 1.5rem 1.5rem 1.5rem;
      max-width: 320px;
      flex: 1 1;
      text-align: left;
      border: 1px solid #f5e7e1;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .loja.clean h2 {
      margin: 0 0 0.5rem 0;
      color: #b48a78;
      font-size: 2rem;
      letter-spacing: 0.5px;
      font-weight: 600;
    }

    .loja.clean p {
      margin: 0 0 0.5rem 0;
      color: #5a463c;
      font-size: 1.4rem;
    }

    .loja.clean a {
      color: #fff;
      background: linear-gradient(90deg, #b48a78 60%, #e7bfa8 100%);
      padding: 0.45rem 1.1rem;
      border-radius: 5px;
      text-decoration: none;
      font-weight: 500;
      font-size: 0.98rem;
      box-shadow: 0 1px 4px rgba(180, 138, 120, 0.08);
      margin-top: 0.5rem;
      align-self: flex-start;
      border: none;
      transition: none;
    }

    @media (max-width: 900px) {
      .mapa-container {
        max-width: 98vw;
        height: 220px;
      }

      .mapa-container iframe {
        height: 220px;
      }

      .lojas-lista {
        flex-direction: column;
        align-items: center;
      }

      .loja.clean {
        max-width: 95vw;
        width: 100%;
        height: 150px;
      }
    }
  </style>

</BaseBody>

</html>