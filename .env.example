# URL da API (opcional). Se vazio, usa o endpoint padrão de statuses no código.
# PONTOMAIS_URL=https://api.pontomais.com.br/api/...

# --- Autenticação tipo Devise Token Auth (headers iguais ao Network no navegador) ---
PONTOMAIS_ACCESS_TOKEN=
PONTOMAIS_CLIENT=
PONTOMAIS_UID=
PONTOMAIS_EXPIRY=
PONTOMAIS_TOKEN_TYPE=Bearer

# --- Sessão / outros formatos (use o que o Network mostrar) ---
PONTOMAIS_COOKIE=
PONTOMAIS_AUTHORIZATION=

# --- Headers que algumas APIs exigem junto com o token ---
PONTOMAIS_REFERER=
PONTOMAIS_ORIGIN=
PONTOMAIS_USER_AGENT=

# CSRF (se o servidor mandar um destes nomes, use o mesmo valor em um só lugar abaixo)
PONTOMAIS_X_CSRF_TOKEN=

PONTOMAIS_X_REQUESTED_WITH=
PONTOMAIS_DEVICE_ID=

# Qualquer header extra: objeto JSON com nomes em minúsculas como o fetch espera.
# Exemplo: {"x-api-version":"1"}
# PONTOMAIS_EXTRA_HEADERS_JSON=

# Intervalo de atualização do cache em ms (2 min = 120000)
PONTOMAIS_REFRESH_MS=120000

# PORT é definido pelo Render em produção.
# PORT=3000
